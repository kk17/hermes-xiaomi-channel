# ──────────────────────────────────────────────
# Hermes Xiaomi Channel — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file.

# Xiaomi account credentials (required)
# Your Xiaomi account username (email or phone number)
MI_USER=your_xiaomi_account@example.com
# Your Xiaomi account password
MI_PASS=your_password_here

# Device ID (optional — will auto-select first speaker if not set)
# Use `micli list` or `micli mina` to find your device DID
MI_DID=

# Wake word / trigger keyword (required)
# When the user says "小爱同学" to wake the speaker, then includes this keyword,
# the message is forwarded to Hermes instead of XiaoAi's default response.
XIAOMI_TRIGGER=阿峰

# Polling interval in seconds (optional, default: 0.5)
XIAOMI_POLL_INTERVAL=0.5

# Suppress XiaoAi's original response when triggered (optional, default: true)
XIAOMI_MUTE_DEFAULT=true

# Default device name for multi-speaker setups (optional)
# If set, messages are routed to this speaker
XIAOMI_DEFAULT_DEVICE=
